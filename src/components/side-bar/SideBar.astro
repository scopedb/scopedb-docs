---
import type {SidebarItem} from '@/interface/sidebar';
import {SideBarMenu} from '../menu';

interface Props {
  sidebar: SidebarItem[];
}

const {sidebar} = Astro.props;

const sidebarClasses = {
  'w-full': true,
  'max-w-[240px]': true,
  'p-4': true,
  'border-gray-200': true,
  'max-h-[calc(100vh-6em)]': true,
  'overflow-y-auto': true,
};
---

<aside class:list={sidebarClasses}>
  <SideBarMenu sidebar={sidebar} client:only />
</aside>

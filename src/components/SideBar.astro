---
import Menu from './menu/Menu.astro';
import {sidebarItems} from '@/config';

const sidebarClasses = {
  'w-full': true,
  'max-w-[240px]': true,
  'p-4': true,
  'border-gray-200': true,
  'max-h-[calc(100vh-6em)]': true,
  'bg-gray-100': true,
  'overflow-y-auto': true,
};
---

<aside class:list={sidebarClasses}>
  <Menu items={sidebarItems} variant="sidebar" />
</aside>

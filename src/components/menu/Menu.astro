---
import type {Sidebar, SidebarItem} from '@/interface/sidebar';

interface Props {
  items?:  Sidebar;
}

// TODO: support collapsed/collapsible prop
// FIXME: correct the active logic
// TODO: mobile view sidebar
const currentPath = Astro.url.pathname;
const isActive = (link: string, hasChildren = false) => {
  if (link === '#') {
    return false;
  }

  // 处理父级菜单的高亮逻辑
  if (hasChildren) {
    // 如果当前路径完全匹配，直接返回true
    if (currentPath === link) {
      return true;
    }
    // 提取前缀进行比较
    const urlParts = link.split('/').filter(Boolean);
    const currentParts = currentPath.split('/').filter(Boolean);

    // 如果href有前缀部分，检查当前路径是否匹配这个前缀
    if (urlParts.length > 0 && currentParts.length > 0) {
      return urlParts[0] === currentParts[0];
    }
    // 检查是否是子路径
    return currentPath.includes(link + '/');
  }

  // 子菜单项也使用前缀匹配
  const urlParts = link.split('/').filter(Boolean);
  const currentParts = currentPath.split('/').filter(Boolean);

  if (urlParts.length > 0 && currentParts.length > 0) {
    return urlParts[0] === currentParts[0];
  }

  return currentPath === link;
};

const SIDEBAR_CLASSES = {
  link: 'block py-2 px-3 text-sm text-gray-700 hover:text-gray-900 hover:bg-gray-50 rounded-md',
  activeLink: 'text-blue-500 bg-blue-50',
  group: 'mb-4',
  groupTitle:
    'sidebar-group-title flex items-center justify-between font-medium text-gray-900 mb-2 p-2 cursor-pointer hover:text-blue-500 rounded-md hover:bg-gray-50',
  groupContent: 'ml-2 space-y-1',
  icon: 'w-4 h-4',
} as const;

const {items} = Astro.props;
---

{
  
    <nav class="space-y-1 overflow-y-auto h-full">
      {
        (items as SidebarItem[]).map((item, index: number) => (
          <div class={SIDEBAR_CLASSES.group}>
            {
              item.items ? (
                <div data-group-id={index}>
                  <div
                    class:list={[
                      SIDEBAR_CLASSES.groupTitle,
                      // {[SIDEBAR_CLASSES.activeLink]: isActive(item.link, true)},
                    ]}
                  >
                    <span>{item.text}</span>
                    <svg
                      class={SIDEBAR_CLASSES.icon}
                      fill="none"
                      stroke="currentColor"
                      viewBox="0 0 24 24"
                    >
                      <path
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        stroke-width="2"
                        d="M9 5l7 7-7 7"
                      />
                    </svg>
                  </div>
                  <div class={`${SIDEBAR_CLASSES.groupContent} hidden`} data-content>
                    {
                      item?.items?.map(item => (
                        <a
                          href={item.link}
                          class:list={[
                            SIDEBAR_CLASSES.link,
                            // {[SIDEBAR_CLASSES.activeLink]: isActive(child.link)},
                          ]}
                        >
                          {item.text}
                        </a>
                      ))
                    }
                  </div>
                </div>
              ) : (
                <a
                  href={item.link}
                  class:list={[
                    SIDEBAR_CLASSES.link,
                    {[SIDEBAR_CLASSES.activeLink]: isActive(item.link ?? '')},
                  ]}
                >
                  {item.text}
                </a>
              )
            }
          </div>
        ))
      }
    </nav>
}

<script define:vars={{SIDEBAR_CLASSES}}>
// 保持引用以避免重复查询 DOM
let initialized = false;

function initializeSidebar() {
  if (initialized) {
    return;
  }

  // 处理所有侧边栏组
  document.querySelectorAll('[data-group-id]').forEach(group => {
    const title = group.querySelector('.sidebar-group-title'); // 使用简单的类名选择器
    const content = group.querySelector('[data-content]');
    const icon = title?.querySelector('svg');

    if (!content || !icon || !title) {
      return;
    }

    title.addEventListener('click', () => {
      content.classList.toggle('hidden');
      icon.classList.toggle('rotate-90');
    });

    // 检查是否需要展开当前项
    const hasActiveChild = content.querySelector(`.${SIDEBAR_CLASSES.activeLink}`);
    if (hasActiveChild) {
      content.classList.remove('hidden');
      icon.classList.add('rotate-90');
      icon.classList.add('translate-z-0');
    }
  });

  initialized = true;
}

// 确保 DOM 完全加载后初始化
if (document.readyState === 'loading') {
  document.addEventListener('DOMContentLoaded', initializeSidebar);
}
else {
  initializeSidebar();
}

// 移动端菜单切换
const menuButton = document.getElementById('menuButton');
const mobileMenu = document.getElementById('mobileMenu');

menuButton?.addEventListener('click', () => {
  mobileMenu?.classList.toggle('hidden');
});

// 移动端下拉菜单
document.querySelectorAll('.mobile-dropdown button').forEach(button => {
  button.addEventListener('click', () => {
    const content = button.nextElementSibling;
    const icon = button.querySelector('svg');

    content?.classList.toggle('hidden');
    icon?.classList.toggle('rotate-90');
  });
});
</script>

<style>
.mobile-dropdown button:focus svg {
  transform: rotate(90deg);
}

[data-content] {
  transition: all 0.3s ease-in-out;
}
</style>

---
import type {Sidebar, SidebarItem} from '@/interface/sidebar';

interface MenuItem {
  text: string;
  link: string;
  items?: MenuItem[];
}

interface Props {
  items?: MenuItem[] | Sidebar;
  variant?: 'navbar' | 'sidebar';
}

const menuItems: MenuItem[] = [
  {text: '首页', link: '/'},
  {text: '关于我们', link: '/about'},
  {
    text: '产品',
    link: '/products',
    items: [
      {text: '产品1', link: '/products/1'},
      {text: '产品2', link: '/products/2'},
    ],
  },
  {text: '联系我们', link: '/contact'},
];
// TODO: support collapsed/collapsible prop
// FIXME: correct the active logic
// TODO: mobile view sidebar
const currentPath = Astro.url.pathname;
const isActive = (link: string, hasChildren = false) => {
  if (link === '#') {
    return false;
  }

  // 处理父级菜单的高亮逻辑
  if (hasChildren) {
    // 如果当前路径完全匹配，直接返回true
    if (currentPath === link) {
      return true;
    }
    // 提取前缀进行比较
    const urlParts = link.split('/').filter(Boolean);
    const currentParts = currentPath.split('/').filter(Boolean);

    // 如果href有前缀部分，检查当前路径是否匹配这个前缀
    if (urlParts.length > 0 && currentParts.length > 0) {
      return urlParts[0] === currentParts[0];
    }
    // 检查是否是子路径
    return currentPath.includes(link + '/');
  }

  // 子菜单项也使用前缀匹配
  const urlParts = link.split('/').filter(Boolean);
  const currentParts = currentPath.split('/').filter(Boolean);

  if (urlParts.length > 0 && currentParts.length > 0) {
    return urlParts[0] === currentParts[0];
  }

  return currentPath === link;
};

const SIDEBAR_CLASSES = {
  link: 'block py-2 px-3 text-sm text-gray-700 hover:text-gray-900 hover:bg-gray-50 rounded-md',
  activeLink: 'text-blue-500 bg-blue-50',
  group: 'mb-4',
  groupTitle:
    'sidebar-group-title flex items-center justify-between font-medium text-gray-900 mb-2 p-2 cursor-pointer hover:text-blue-500 rounded-md hover:bg-gray-50',
  groupContent: 'ml-2 space-y-1',
  icon: 'w-4 h-4',
} as const;

const {items = menuItems, variant = 'navbar'} = Astro.props;
---

{
  variant === 'sidebar' ? (
    <nav class="space-y-1 overflow-y-auto h-full">
      {
        (items as SidebarItem[]).map((item, index: number) => (
          <div class={SIDEBAR_CLASSES.group}>
            {
              item.items ? (
                <div data-group-id={index}>
                  <div
                    class:list={[
                      SIDEBAR_CLASSES.groupTitle,
                      // {[SIDEBAR_CLASSES.activeLink]: isActive(item.link, true)},
                    ]}
                  >
                    <span>{item.text}</span>
                    <svg
                      class={SIDEBAR_CLASSES.icon}
                      fill="none"
                      stroke="currentColor"
                      viewBox="0 0 24 24"
                    >
                      <path
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        stroke-width="2"
                        d="M9 5l7 7-7 7"
                      />
                    </svg>
                  </div>
                  <div class={`${SIDEBAR_CLASSES.groupContent} hidden`} data-content>
                    {
                      item?.items?.map(item => (
                        <a
                          href={item.link}
                          class:list={[
                            SIDEBAR_CLASSES.link,
                            // {[SIDEBAR_CLASSES.activeLink]: isActive(child.link)},
                          ]}
                        >
                          {item.text}
                        </a>
                      ))
                    }
                  </div>
                </div>
              ) : (
                <a
                  href={item.link}
                  class:list={[
                    SIDEBAR_CLASSES.link,
                    {[SIDEBAR_CLASSES.activeLink]: isActive(item.link ?? '')},
                  ]}
                >
                  {item.text}
                </a>
              )
            }
          </div>
        ))
      }
    </nav>
  ) : (
    <nav class="bg-white shadow-lg">
      <div class="max-w-6xl mx-auto px-4">
        <div class="flex justify-between">
          <!-- Logo -->
          <div class="flex space-x-4">
            <a href="/" class="flex items-center py-5 px-2 text-gray-700 hover:text-gray-900">
              <svg
                class="h-6 w-6 mr-1 text-blue-500"
                xmlns="http://www.w3.org/2000/svg"
                fill="none"
                viewBox="0 0 24 24"
                stroke="currentColor"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M12 19l9 2-9-18-9 18 9-2zm0 0v-8"
                />
              </svg>
              <span class="font-bold">网站名称</span>
            </a>
          </div>

          <!-- 桌面导航 -->
          <div class="hidden md:flex items-center space-x-1">
            {
              items.map(item => (
            item.children ? (
                <div class="relative group">
                  <button
                    class:list={[
                      'py-5 px-3 flex items-center',
                      isActive(item.link, true) ? 'text-blue-500' : 'text-gray-700 hover:text-gray-900',
                    ]}
                  >
                    {item.text}
                    <svg class="w-4 h-4 ml-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
                    </svg>
                  </button>
                  <div class="absolute hidden group-hover:block bg-white shadow-lg rounded-md mt-0 w-48">
                    {
                      item.children.map((child: any) => (
                        <a
                          href={child.link}
                          class:list={[
                            'block px-4 py-2 text-gray-700 hover:bg-gray-100',
                            {'bg-gray-100': isActive(child.link)},
                          ]}
                        >
                          {child.text}
                        </a>
                      ))
                    }
                  </div>
                </div>
              ) : (
                <a
                  href={item.link}
                  class:list={[
                    'py-5 px-3',
                    isActive(item.link)
                      ? 'text-blue-500 border-b-2 border-blue-500'
                      : 'text-gray-700 hover:text-gray-900',
                  ]}
                >
                  {item.text}
                </a>
              )
          ))
            }
          </div>

          <!-- 移动端菜单按钮 -->
          <button id="menuButton" class="md:hidden p-2 focus:outline-none">
            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
            </svg>
          </button>
        </div>

        <!-- 移动端菜单 -->
        <div id="mobileMenu" class="hidden md:hidden pb-4">
          {
            (items as MenuItem[]).map(item => (
          item.items ? (
              <div class="mobile-dropdown">
                <button class="w-full text-left px-3 py-2 flex justify-between items-center">
                  {item.text}
                  <svg
                    class="w-4 h-4 transform transition-transform duration-200"
                    fill="none"
                    stroke="currentColor"
                    viewBox="0 0 24 24"
                  >
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
                  </svg>
                </button>
                <div class="hidden pl-4">
                  {
                    item.items.map((child: any) => (
                      <a
                        href={child.link}
                        class:list={[
                          'block px-3 py-2',
                          isActive(child.link) ? 'text-blue-500' : 'text-gray-700 hover:text-gray-900',
                        ]}
                      >
                        {child.text}
                      </a>
                    ))
                  }
                </div>
              </div>
            ) : (
              <a
                href={item.link}
                class:list={[
                  'block px-3 py-2',
                  isActive(item.link) ? 'text-blue-500' : 'text-gray-700 hover:text-gray-900',
                ]}
              >
                {item.text}
              </a>
            )
        ))
          }
        </div>
      </div>
    </nav>
  )
}

<script define:vars={{SIDEBAR_CLASSES}}>
// 保持引用以避免重复查询 DOM
let initialized = false;

function initializeSidebar() {
  if (initialized) {
    return;
  }

  // 处理所有侧边栏组
  document.querySelectorAll('[data-group-id]').forEach(group => {
    const title = group.querySelector('.sidebar-group-title'); // 使用简单的类名选择器
    const content = group.querySelector('[data-content]');
    const icon = title?.querySelector('svg');

    if (!content || !icon || !title) {
      return;
    }

    title.addEventListener('click', () => {
      content.classList.toggle('hidden');
      icon.classList.toggle('rotate-90');
    });

    // 检查是否需要展开当前项
    const hasActiveChild = content.querySelector(`.${SIDEBAR_CLASSES.activeLink}`);
    if (hasActiveChild) {
      content.classList.remove('hidden');
      icon.classList.add('rotate-90');
      icon.classList.add('translate-z-0');
    }
  });

  initialized = true;
}

// 确保 DOM 完全加载后初始化
if (document.readyState === 'loading') {
  document.addEventListener('DOMContentLoaded', initializeSidebar);
}
else {
  initializeSidebar();
}

// 移动端菜单切换
const menuButton = document.getElementById('menuButton');
const mobileMenu = document.getElementById('mobileMenu');

menuButton?.addEventListener('click', () => {
  mobileMenu?.classList.toggle('hidden');
});

// 移动端下拉菜单
document.querySelectorAll('.mobile-dropdown button').forEach(button => {
  button.addEventListener('click', () => {
    const content = button.nextElementSibling;
    const icon = button.querySelector('svg');

    content?.classList.toggle('hidden');
    icon?.classList.toggle('rotate-90');
  });
});
</script>

<style>
.mobile-dropdown button:focus svg {
  transform: rotate(90deg);
}

[data-content] {
  transition: all 0.3s ease-in-out;
}
</style>

---
const searchClasses = {
    'w-full': true,
    'h-10': true,
    'px-4': true,
    'text-sm': true,
    'border': true,
    'border-gray-300': true,
    'rounded-md': true,
    'focus:outline-none': true,
    'focus:ring-2': true,
    'focus:ring-blue-500': true,
}
---

<input 
    type="search" 
    class:list={searchClasses}
    placeholder="Search..." 
/>
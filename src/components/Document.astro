---
import "@/styles/global.css";
import type { MarkdownHeading } from "astro";
import Toc from "./Toc.astro";

interface Props {
    headings: MarkdownHeading[];
}

const { headings } = Astro.props;
const toc = headings.filter((heading) => heading.depth  >1&&heading.depth<= 3);
---

<div class="grid grid-cols-10 gap-x-[32px]">
    <div class="col-span-2">
        <div class="sticky top-48">Sidebar</div>
    </div>
    <div class="markdown-body col-span-6"><slot /></div>
    <div class="col-span-2">
        {toc.length>0?<Toc toc={toc} />:null}
    </div>
</div>
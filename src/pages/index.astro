---
import Layout from '@/layouts/Layout.astro';

// TODO: replace with real data before releases
const mostPopular = [
  {
    category: 'User Guide',
    title: 'Connecting to ScopeDB',
    description: 'Learn about the applications and tools that you can use to access Snowflake',
    link: '/docs/connecting-to-scopedb',
  },
  {
    category: 'User Guide',
    title: 'Louis Vuitton',
    description: 'Learn about the applications and tools that you can use to access Snowflake',
    link: '/docs/louis-vuitton',
  },
  {
    category: 'User Guide',
    title: 'The Walt Disney Company',
    description: 'Learn about the applications and tools that you can use to access Snowflake',
    link: '/docs/the-walt-disney-company',
  },
];

const basics = [
  {
    title: 'Medical Assistant',
    description: 'Learn about the applications and tools that you can use to access Snowflake',
    link: '/docs/medical-assistant',
  },
  {
    title: 'The Walt Disney Company',
    description: 'Learn about the applications and tools that you can use to access Snowflake',
    link: '/docs/the-walt-disney-company',
  },
  {
    title: 'Biffco Enterprises Ltd.',
    description: 'Learn about the applications and tools that you can use to access Snowflake',
    link: '/docs/biffco-enterprises',
  },
  {
    title: 'Big Kahuna Burger Ltd.',
    description: 'Learn about the applications and tools that you can use to access Snowflake',
    link: '/docs/big-kahuna-burger',
  },
  {
    title: 'Connecting to ScopeDB',
    description: 'Learn about the applications and tools that you can use to access Snowflake',
    link: '/docs/connecting-to-scopedb',
  },
  {
    title: 'Big Kahuna Burger Ltd.',
    description: 'Learn about the applications and tools that you can use to access Snowflake',
    link: '/docs/big-kahuna-burger',
  },
];
---
<Layout title="Welcome to ScopeDB">
  <div class="home-container">
    <div>
      <div>
        <div class="title">ScopeDB<br />Documentation</div>
        <div class="desc">Get an overview of ScopeDB's features, integrations, and how to use them.</div>
      </div>
    </div>
    <div class="info">
      <div>
        <div class="most-popular-title">Most popular</div>
        <div class="card-list">
          {
            mostPopular.map(item => (
              <a class="card" href={item.link}>
                <div class="most-popular-category">{item.category}</div>
                <div class="most-popular-title-inner">{item.title}</div>
                <div class="most-popular-desc">{item.description}</div>
              </a>
            ))
          }
        </div>
      </div>
      <div>
        <div class="basics-title">ScopeBD basics</div>
        <div class="card-list">
          {
            basics.map(item => (
              <a class="card" href={item.link}>
                <div class="basics-title-inner">{item.title}</div>
                <div class="basics-desc">{item.description}</div>
              </a>
            ))
          }
        </div>
      </div>
    </div>
  </div>
</Layout>

<script>
const lis = document.querySelectorAll('.toc-li');
lis.forEach(li => {
  li.addEventListener(
    'click',
    e => {
      const liDom = e.currentTarget as HTMLElement;
      const id = liDom.id;
      const dom = document.querySelector(`#${id}`);
      dom?.scrollIntoView({behavior: 'smooth', block: 'center'});
    },
    true
  );
});
</script>

<style>
.home-container {
  display: flex;
  flex-direction: column;
  justify-content: center;
  background: linear-gradient(
    to bottom,
    #fbfbfb 0%,
    #ecf5fb 46%,
    #fff 46%,
    #fff 100%
  );
  max-width: 100%;
  padding: 0 100px;
}
@media (max-width: 900px) {
  .home-container {
    padding: 0 20px;
  }
}
.title {
  color: #000;
  font-size: 46px;
  font-weight: 500;
  line-height: 120%;
  margin-top: 73px;
  margin-bottom: 20px;
}
.desc {
  max-width: 520px;
  height: 71px;
  color: #000;
  font-size: 24px;
  font-weight: 400;
  line-height: 150%;
  margin-bottom: 73px;
}

.most-popular-title {
  color: #000;
  font-size: 16px;
  font-weight: 500;
  line-height: 150%;
  margin-bottom: 27px;
}
.card-list {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 1.5rem;
  margin-bottom: 60px;
}
@media (max-width: 900px) {
  .card-list {
    grid-template-columns: 1fr;
  }
}
.card {
  background: #fff;
  border-radius: 16px;
  padding: 1.5rem;
  display: flex;
  flex-direction: column;
  gap: 0.5rem;
  text-decoration: none;
  transition: box-shadow 0.2s;
  box-shadow: 0px 5px 14px 2px #f3f3f3;
}
.card:hover {
  box-shadow: 0 4px 16px 0 rgba(0, 0, 0, 0.10);
}
.most-popular-category {
  color: #71717a;
  font-size: 0.875rem;
  font-weight: 500;
}
.most-popular-title-inner, .basics-title-inner {
  font-weight: bold;
  font-size: 1.125rem;
  color: #222;
}
.most-popular-desc, .basics-desc {
  color: #71717a;
  font-size: 0.95rem;
}
.basics-container {
  margin-bottom: 45px;
}
.basics-title {
  font-weight: 600;
  font-size: 1.125rem;
  margin-bottom: 27px;
}
.basics-list {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 1.5rem;
}
@media (max-width: 900px) {
  .basics-list {
    grid-template-columns: 1fr;
  }
}
.basics-card {
  background: #f5f5f5;
  border-radius: 16px;
  padding: 1.5rem;
  display: flex;
  flex-direction: column;
  gap: 0.5rem;
  text-decoration: none;
  transition: box-shadow 0.2s;
}
.basics-card:hover {
  box-shadow: 0 2px 8px 0 rgba(0, 0, 0, 0.06);
}
.basics-title-inner {
  font-weight: bold;
  font-size: 1.125rem;
  color: #222;
}
.basics-desc {
  color: #71717a;
  font-size: 0.95rem;
}
</style>
